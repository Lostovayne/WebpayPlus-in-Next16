# ─── Webpay Integration — Variables de Entorno ────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env — sólo .env.example.
#
# Cada sección indica dónde obtener las variables y su valor por defecto en desarrollo.

# ─── Transbank ────────────────────────────────────────────────────────────────
# Fuente: https://www.transbankdevelopers.cl
# En integración usa las credenciales públicas de abajo.
# En producción: reemplaza con tus credenciales reales de Transbank.

# Código de comercio otorgado por Transbank.
# Default (integración): 597055555532
WEBPAY_COMMERCE_CODE=597055555532

# Llave secreta de API otorgada por Transbank.
# Default (integración): 579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
WEBPAY_API_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C

# Entorno de Transbank. Valores posibles: integration | production
# Default: integration
WEBPAY_ENVIRONMENT=integration

# ─── Base de Datos (Prisma + PostgreSQL) ──────────────────────────────────────
# Fuente: Tu proveedor de PostgreSQL (Neon, Supabase, Prisma Postgres, etc.)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Default: sin default (requerido)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ─── Aplicación ───────────────────────────────────────────────────────────────
# URL base de tu aplicación. Transbank usará esta URL para el return_url.

# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Worker de Polling (Cron Job) ─────────────────────────────────────────────
# Secret compartido entre Vercel Cron Jobs y el endpoint /api/webpay/poll.
# Genera uno seguro con: openssl rand -hex 32
# Default: sin default (requerido)
CRON_SECRET=reemplaza_con_un_secret_de_al_menos_32_caracteres_generado_con_openssl

# ─── Upstash (Rate Limiting + BetterAuth Secondary Storage) ───────────────────
# Fuente: https://console.upstash.com
# Opcional en desarrollo (usa memory fallback).
# Requerido en producción para rate limiting persistente en serverless.

# URL del servidor Redis de Upstash (HTTP).
# Default: sin default (opcional en dev)
UPSTASH_REDIS_REST_URL=https://<region>.upstash.io

# Token de acceso a Upstash Redis.
UPSTASH_REDIS_REST_TOKEN=<token>

# ─── BetterAuth ──────────────────────────────────────────────────────────────
# Fuente: https://www.better-auth.com
# Secret: genera con: openssl rand -base64 32
# URL: en dev usa http://localhost:3000, en producción tu dominio real.

# Secret de cifrado para BetterAuth (mínimo 32 caracteres).
# Default: sin default (requerido)
BETTER_AUTH_SECRET=reemplaza_con_un_secret_de_al_menos_32_caracteres

# URL base de la aplicación para BetterAuth.
# Default (solo en dev): http://localhost:3000
# En producción: REQUERIDO, sin default
BETTER_AUTH_URL=http://localhost:3000

# ─── Resend (Email Service) ─────────────────────────────────────────────────
# Fuente: https://resend.com
# API Key: https://resend.com/api-keys
# From Email: debe estar en un dominio verificado en Resend.
# Opcional en desarrollo (logs en vez de envíos reales).
# Requerido en producción para emails de verificación, OTP y reset.

# API key de Resend para envío de emails de autenticación.
# Default: sin default (opcional en dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente para emails de autenticación.
# Default: sin default (opcional en dev)
RESEND_FROM_EMAIL=auth@tu-dominio.com
