# ─── Webpay Integration — Variables de Entorno ────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env — sólo .env.example.

# ─── Transbank ────────────────────────────────────────────────────────────────

# Código de comercio otorgado por Transbank.
# En integración usa: 597055555532
WEBPAY_COMMERCE_CODE=597055555532

# Llave secreta de API otorgada por Transbank.
# En integración usa: 579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
WEBPAY_API_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C

# Entorno de Transbank. Valores posibles: integration | production
WEBPAY_ENVIRONMENT=integration

# ─── Base de Datos (Prisma + PostgreSQL) ──────────────────────────────────────

# URL de conexión a la base de datos PostgreSQL.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# En Prisma Postgres (prisma.io): postgresql://USER:PASSWORD@pooled.db.prisma.io:5432/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ─── Aplicación ───────────────────────────────────────────────────────────────

# URL base de tu aplicación. Transbank usará esta URL para el return_url.
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Worker de Polling (Cron Job) ─────────────────────────────────────────────

# Secret compartido entre Vercel Cron Jobs y el endpoint /api/webpay/poll.
# Genera uno seguro con: openssl rand -hex 32
# Ejemplo: a3f9b2c1d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1
CRON_SECRET=reemplaza_con_un_secret_de_al_menos_32_caracteres_generado_con_openssl

# ─── Upstash (Rate Limiting) ────────────────────────────────────────────────

# URL del servidor Redis de Upstash (HTTP).
# Créalo en https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://<region>.upstash.io

# Token de acceso a Upstash Redis.
UPSTASH_REDIS_REST_TOKEN=<token>
