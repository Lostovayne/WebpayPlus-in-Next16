generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WebpayTransaction {
  id        String  @id @default(uuid(7))
  buyOrder  String  @unique @map("buy_order") @db.VarChar(26)
  sessionId String  @map("session_id") @db.VarChar(61)
  amount    Decimal @db.Decimal(17, 2)
  token     String? @unique @db.VarChar(64)
  status    String  @default("INITIALIZED") @db.VarChar(20)

  // Return data via callback
  vci                String?   @db.VarChar(10)
  cardNumber         String?   @map("card_number") @db.VarChar(19)
  accountingDate     String?   @map("accounting_date") @db.VarChar(4)
  transactionDate    DateTime? @map("transaction_date")
  authCode           String?   @map("auth_code") @db.VarChar(6)
  paymentTypeCode    String?   @map("payment_type_code") @db.VarChar(2)
  responseCode       Int?      @map("response_code")
  installmentsAmount Decimal?  @map("installments_amount") @db.Decimal(17, 2)
  installmentsNumber Int?      @map("installments_number")
  abortedReason      String?   @map("aborted_reason") @db.VarChar(50)
  polledAt           DateTime? @map("polled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt, polledAt])
  @@map("webpay_transactions")
}
